{
    "name": "beon/laravel",
    "description": "Send WhatsApp messages from Laravel in 3 lines — powered by Beon API",
    "keywords": ["laravel", "whatsapp", "beon", "messaging", "otp", "package"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Yasser Farag Abdelhamid",
            "role": "Backend Engineer",
            "homepage": "https://wa.me/201000830792"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Beon\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beon\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Beon\\Laravel\\BeonServiceProvider"
            ],
            "aliases": {
                "Beon": "Beon\\Laravel\\Facades\\Beon"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
